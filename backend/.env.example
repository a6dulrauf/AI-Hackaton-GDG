# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
# Free tiers only — see docs/PLAN.md §5.

# Groq — chat parsing/classification + Whisper voice. https://console.groq.com → API Keys
GROQ_API_KEY=

# Gemini — reserved for the Problem-2 OCR fallback only. https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- WhatsApp (Meta Cloud API) — real outreach -------------------------------
# OPT-IN switch. Leave off (the default) and wave outreach stays fully mocked —
# safest for a demo. Set to true (or flip the header toggle at runtime) to send
# real messages to contacted donors. Has no effect unless creds below are set.
WHATSAPP_ENABLED=false
# From developers.facebook.com -> your app -> WhatsApp -> API Setup.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Any string you invent; the inbound webhook echoes it back to verify with Meta.
WHATSAPP_VERIFY_TOKEN=lifeline-verify
# Optional: while on the free test number, route ALL outbound to this one verified
# recipient (digits + country code, no +). e.g. 923001234567. Leave blank in prod.
WHATSAPP_DEMO_REDIRECT=
# Optional: override Graph API version (default v21.0).
WHATSAPP_API_VERSION=
